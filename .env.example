# Ambiente
NODE_ENV=development
APP_ENV=local
ALLOW_DEV_LOGIN=true
DEV_LOGIN_KEY=replace_me

# Backend
BACKEND_PORT=3000

# Base de datos
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=udea
DB_USER=udea_owner
DB_PASS=replace_me
DB_AUTO_MIGRATE=true

# OAuth Google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Frontend
FRONTEND_URL=http://localhost:4200

# Auth
JWT_SECRET=replace_me
JWT_EXPIRES_IN=1d
AUTH_ALLOWED_DOMAIN=udea.edu.co

# Pagination
PAGINATION_DEFAULT_PAGE_SIZE=20
PAGINATION_MAX_PAGE_SIZE=100

# DOCX – Programa de curso
DOCX_PROGRAMA_TEMPLATE_PATH=templates/VD-FO-003-plantilla.docx
DOCX_PROGRAMA_TEMPLATE_WATCH=true
DOCX_PROGRAMA_ALLOW_DEBUG=true