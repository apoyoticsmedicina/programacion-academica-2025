{
  "name": "academica",
  "version": "1.0.0",
  "description": "Microservicio de Programación Académica (Node.js + TypeScript + PostgreSQL)",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "nodemon --exec ts-node src/index.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [
    "academica",
    "node",
    "typescript",
    "express",
    "typeorm",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.1.14",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^16.18.122",
    "@types/pg": "^8.6.6",
    "nodemon": "^2.0.22",
    "simple-update-notifier": "^1.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.9.5"
  },
  "overrides": {
    "semver": "7.7.2"
  }
}
